{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "SimplePlane",
  "version": "0.1.4",
  "identifier": "com.simpleplane.desktop",
  "build": {
    "frontendDist": "../web",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "SimplePlane",
        "width": 1100,
        "height": 720,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/proxy-local.jar",
      "resources/jre/**/*",
      "resources/web/**/*",
      "resources/config-templates/**/*",
      "resources/tun-adapter*"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "wix": null,
      "nsis": {
        "installMode": "both"
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "endpoints": [
        "https://github.com/zhh293/SimplePlanePlatform/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEUwRThDQzZBRDBFMEI2MTQKUldRVXR1RFFhc3pvNEpYWjdCNmpZT1JPY1RqNTRVSVR3R1Y3UkZqaThheXNNZkN0T0NjZFRDVFYK"
    }
  }
}
